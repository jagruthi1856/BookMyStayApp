/**
 * Book My Stay Application
 *
 * This class represents the entry point of the Hotel Booking Management System.
 * It demonstrates how a Java application starts execution and prints a welcome message.
 *
 * The program showcases:
 * - Class structure
 * - main() method as entry point
 * - Console output
 * - Basic application flow
 *
 * @author Student
 * @version 1.0
 */
public class UseCase1HotelBookingApp {

    /**
     * Main method - Entry point of the application
     * JVM starts execution from here
     *
     * @param args Command line arguments
     */
    public static void main(String[] args) {

        // Welcome message
        System.out.println("===================================");
        System.out.println("   Welcome to Book My Stay App");
        System.out.println("===================================");

        // Application details
        System.out.println("Application: Hotel Booking Management System");
        System.out.println("Version    : v1.0");

        // Exit message
        System.out.println("\nSystem initialized successfully!");
    }
}